APP_NAME=OpenStudy Backend
APP_ENV=dev
API_BASE_URL=http://localhost:8000

# --- Option A: MySQL（本地/团队默认示例，密码请改成自己的）---
# DATABASE_URL=mysql+aiomysql://root:YOUR_PASSWORD@localhost:3306/openstudy_dev

# --- Option B: Supabase（云端 Postgres）---
# 直连 URL（可二选一：要么直接写 DATABASE_URL，要么写下面分字段）
# DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# DATABASE_HOST=db.rhduntmwejnblgyvprsm.supabase.co
# DATABASE_USER=postgres
# DATABASE_PASSWORD=15768210210yemx
# DATABASE_PORT=5432
# DATABASE_NAME=postgres
# DATABASE_SSL=true
# 校园/公司代理 TLS（仅开发环境）:
# DATABASE_SSL_INSECURE=true

# --- Option C: 本地 SQLite（离线）---
# DATABASE_URL=sqlite+aiosqlite:///./data/dev.db

JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_LONG_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

OHMYGPT_API_KEY=REPLACE_WITH_REAL_KEY_IN_LOCAL_ONLY
OHMYGPT_BASE_URL=https://api.ohmygpt.com/v1

# Quiz audio upload max size in bytes (default 8 MiB)
QUIZ_AUDIO_MAX_BYTES=8388608
